NODE_ENV=development
HOST=0.0.0.0
PORT=5000
API_PREFIX=/api/v1

MONGODB_URI=mongodb://127.0.0.1:27017/baseball-backend

# Public URLs. Change these only when the host/domain changes.
BASE_URL=http://localhost:5000
API_BASE_URL=http://localhost:5000/api/v1

# Production upload storage. Use S3 for stateless hosts such as Render, Railway, and Cloudways.
STORAGE_PROVIDER=s3
UPLOAD_DRIVER=s3
UPLOAD_MODE=server
MAX_UPLOAD_FILE_SIZE_MB=5
ALLOWED_UPLOAD_MIME_TYPES=image/*,video/*

# Required when STORAGE_PROVIDER=s3 / UPLOAD_DRIVER=s3.
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PUBLIC_BASE_URL=

# Local disk uploads are disabled in the backend code.
# UPLOAD_DIR=storage/uploads
# LOCAL_UPLOADS_BASE_PATH=/uploads
# PUBLIC_UPLOAD_URL=http://localhost:5000/uploads

# Browser origins allowed to call the API. Use * to allow all origins.
CORS_ORIGINS=*

LOG_LEVEL=info

DEFAULT_ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

JWT_SECRET=replace-with-a-long-random-secret-at-least-16-chars
JWT_EXPIRES_IN=7d
OTP_EXPIRES_MINUTES=10

RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=no-reply@example.com
